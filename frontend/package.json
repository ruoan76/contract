{
  "name": "contract-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 8080",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 8080",
    "typecheck": "vue-tsc -b --noEmit",
    "generate:api": "openapi-typescript ../backend/openapi.json -o src/types/api.d.ts",
    "test:smoke": "playwright test e2e/smoke-routes.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:local": "echo '请先启动后端: cd ../backend && E2E_BYPASS_AI_GATE=1 uvicorn main:app --reload' && VITE_E2E=1 playwright test"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "element-plus": "^2.9.0",
    "pdfjs-dist": "^4.10.38",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "openapi-typescript": "^7.6.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
