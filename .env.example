# 合同审批平台 — 环境变量示例（复制为 .env 后按需修改）
# 勿将含真实密钥的 .env 提交到版本库

# MySQL
DATABASE_URL=mysql+asyncmy://contract_user:contract_password@localhost:3306/contract_db
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=contract_db
MYSQL_USER=contract_user
MYSQL_PASSWORD=contract_password

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
SECRET_KEY=change-me-in-production

# AI（1=Mock 同步，0=Celery 异步骨架）
AI_REVIEW_MOCK=1

# 文件存储：local | minio
FILE_STORAGE=local
FILE_STORAGE_PATH=/data/contract-files
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=contract-files

# 前端开发（Vite 代理 /api → :8000）
VITE_API_BASE_URL=
