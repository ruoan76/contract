# ==================== 基础配置 ====================
APP_NAME=合同审批管理平台
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ==================== 数据库配置 ====================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=contract_db
MYSQL_USER=contract_user
MYSQL_PASSWORD=contract_password
DATABASE_URL=mysql+asyncmy://contract_user:contract_password@localhost:3306/contract_db

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0

# ==================== JWT 配置 ====================
SECRET_KEY=your-secret-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== AI 配置 ====================
AI_MODEL=mlx-community/Qwen3.6-35B-A3B-4bit
AI_BASE_URL=http://localhost:8000/v1
AI_API_KEY=local
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=4096

# ==================== MinIO 配置 ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=contract-files

# ==================== Celery 配置 ====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== 文件配置 ====================
FILE_STORAGE_PATH=/data/contract-files
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,png

# ==================== 安全配置 ====================
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=/data/logs/contract.log
