# ==============================================================================
# 合同审批管理平台 - 环境配置示例
# ==============================================================================
# 复制此文件为 .env 并修改对应值
# cp .env.example .env
# ==============================================================================

# ---------- 基础配置 ----------
DEBUG=true
ENVIRONMENT=development

# ---------- 服务器配置 ----------
# 合同后端默认 8000（与 frontend/vite.config.ts 的 /api 代理一致）
# MLX 推理端口因本机而异，见 AI_BASE_URL / docs/mlx-local-dev.md
HOST=0.0.0.0
PORT=8000

# ---------- 数据库配置 ----------
DATABASE_URL=mysql+asyncmy://contract_user:contract_password@localhost:3306/contract_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ---------- Redis 配置 ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- JWT 认证配置 ----------
SECRET_KEY=change-this-to-a-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- AI 模型配置 (本地 MLX / Qwen3.6) ----------
# 1=演示 Mock；0=真实 MLX。本地开发可复制 .env.mlx.example
AI_REVIEW_MOCK=1
AI_REVIEW_SYNC=1
AI_MODEL=mlx-community/Qwen3.6-35B-A3B-4bit
# 本机 MLX 端口请用 ps/lsof 探测，示例见 .env.mlx.example（当前环境为 27366）
AI_BASE_URL=http://127.0.0.1:27366/v1
AI_API_KEY=local
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=4096

# ---------- 文件存储配置 ----------
FILE_STORAGE_PATH=/data/contract-files
MAX_FILE_SIZE=52428800
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=contract-files

# ---------- 安全配置 ----------
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# ---------- CORS 配置 ----------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------- 审批配置 ----------
DEFAULT_APPROVAL_TIMEOUT_HOURS=24
AUTO_APPROVE_ENABLED=false
