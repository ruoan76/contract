# MLX 本地开发 — 复制为 backend/.env
# cp .env.mlx.example .env
#
# 探测本机 MLX 端口：
#   ps aux | grep mlx_lm.server
#   curl http://127.0.0.1:<端口>/v1/models
#
# 本机实测（2026-05-25）：
#   MLX 推理  → 127.0.0.1:27366  (mlx_lm.server 已常驻)
#   合同 API  → 127.0.0.1:8000    (与 frontend/vite.config.ts 代理一致)
#   合同前端  → 127.0.0.1:8080    (Vite dev server)
#   勿占用    → 8088(penetration_bff), 8765

DEBUG=true
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

AI_REVIEW_MOCK=0
AI_REVIEW_SYNC=1
AI_MODEL=mlx-community/Qwen3.6-35B-A3B-4bit
AI_BASE_URL=http://127.0.0.1:27366/v1
AI_API_KEY=local
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=6144
# 长合同（2 万字+）建议提高超时，避免单维 json_parse/timeout
AI_REQUEST_TIMEOUT=180

AI_PARSE_MOCK=1

# Phase AI-1/AI-2
AI_AUTO_REVIEW_ON_UPLOAD=0
AI_REVIEW_SELF_CORRECT=1
AI_REQUIRE_CONFIRM=0

# 数据库（本地需 docker compose up mysql）
DATABASE_URL=mysql+asyncmy://contract_user:contract_password@127.0.0.1:3306/contract_db
SECRET_KEY=dev-local-secret-change-in-production
